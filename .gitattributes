# Default: normalize text files to LF in the repo, native on checkout
* text=auto

# Source files always use LF
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.lock text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.pdf binary